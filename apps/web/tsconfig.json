{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "nucleo-core-outline-24": ["./src/icons/lucideNucleoFallback.ts"],
      "nucleo-ui-outline-18": ["./src/icons/nucleoUiOutline18Fallback.ts"],
      "~/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["@effect/platform-node"],
        "diagnosticSeverity": {
          "importFromBarrel": "error",
          "anyUnknownInErrorContext": "warning",
          "instanceOfSchema": "warning",
          "deterministicKeys": "warning"
        }
      }
    ]
  },
  "include": ["src", "vite.config.ts", "test"]
}
